########################################################################
########################################################################
# Makefile for bootstrapping
########################################################################
########################################################################
CAT=cat
SED=sed
ECHO=echo
MAKE=make
NODE=node
########################################################################
########################################################################
all:: lib2xats2cm
########################################################################
########################################################################
clean:: ; rm -f *~
cleanall:: ; rm -f *~
########################################################################
cleanall:: ; rm -f BUILD/JS/*_sats_out0.js
cleanall:: ; rm -f BUILD/JS/*_dats_out?.js
########################################################################
########################################################################
#
SRCSATS := \
xats2cm.sats \
#
########################################################################
#
SRCDATS := \
xats2cm.dats \
xats2cm_dynexp.dats \
xats2cm_decl00.dats \
cm1emit.dats \
cm1emit_utils0.dats \
cm1emit_dynexp.dats \
cm1emit_decl00.dats \
#
########################################################################
########################################################################
OUT0SATS := \
$(patsubst %.sats, BUILD/JS/%_sats_out0.js, $(SRCSATS))
OUT0DATS := \
$(patsubst %.dats, BUILD/JS/%_dats_out0.js, $(SRCDATS))
OUT1DATS := \
$(patsubst %.dats, BUILD/JS/%_dats_out1.js, $(SRCDATS))
########################################################################
########################################################################
-include .depend_xjsemit
########################################################################
########################################################################
BUILD/JS/%_sats_out0.js: SATS/%.sats; \
$(NODE) --stack-size=8801 $(XATSOPT_TCHECK00) $< > $@
BUILD/JS/%_dats_out0.js: DATS/%.dats; \
$(NODE) --stack-size=8801 $(XATS2JS_JSEMIT00) $< > $@
########################################################################
########################################################################
N001="X"
N002=$(N001) $(N001)
N004=$(N002) $(N002)
N008=$(N004) $(N004)
N016=$(N008) $(N008)
N032=$(N016) $(N016)
N064=$(N032) $(N032)
N128=$(N064) $(N064)
N256=$(N128) $(N128)
N512=$(N256) $(N256)
NFILE=$(N064) $(N032) $(N004) # 100=064+032+004
##################################################################
BUILD/JS/%_dats_out1.js: \
BUILD/JS/%_dats_out0.js; \
$(eval NFILE=$(NFILE) X) \
$(SED) -e 's/jsxtnm/jsx$(words $(NFILE))tnm/g' $< > $@
##################################################################
lib2xats2cm: $(OUT1DATS); $(CAT) $(OUT1DATS) > lib/lib2xats2cm.js
########################################################################
########################################################################
XASSETS=\
./../../../xassets
########################################################################
ifndef XATSOPT_TCHECK00
XATSOPT_TCHECK00=$(XASSETS)/JS/xatsopt/xatsopt_tcheck00_ats2_opt1.js
endif ## (ifeq($(XATSOPT_TCHECK00),""))
########################################################################
ifndef XATS2JS_JSEMIT00
XATS2JS_JSEMIT00=$(XASSETS)/JS/xats2js/xats2js_jsemit00_ats2_opt1.js
endif ## (ifeq($(XATS2JS_JSEMIT00),""))
########################################################################
########################################################################
#######################(end-of-[Makefile_xjsemit])######################
########################################################################
########################################################################
